{
  "name": "savy",
  "version": "1.0.0",
  "description": "SAVY \u2014 AI Meal Delivery App",
  "main": "index.html",
  "scripts": {
    "cap:init": "npx cap init SAVY app.savy.delivery --web-dir .",
    "cap:android": "npx cap add android && npx cap sync android",
    "cap:ios": "npx cap add ios && npx cap sync ios",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:run:android": "npx cap run android",
    "cap:run:ios": "npx cap run ios",
    "cap:build:android": "npx cap build android",
    "cap:build:ios": "npx cap build ios"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/clipboard": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  }
}
